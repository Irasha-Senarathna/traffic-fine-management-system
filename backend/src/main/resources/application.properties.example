# ============================================================================
# EXAMPLE Application Configuration
# ============================================================================
# IMPORTANT: This is a TEMPLATE file
# Copy this to: application.properties
# Fill in YOUR OWN credentials before running the app
# NEVER commit application.properties to Git (it contains passwords!)
# ============================================================================

# ============================================================================
# MySQL Database Connection
# ============================================================================
# Database URL - Change hostname/port if needed
spring.datasource.url=jdbc:mysql://localhost:3306/traffic_fine_db

# Database Username - Usually 'root' for local development
spring.datasource.username=root

# Database Password - YOUR PASSWORD HERE (remove this line if using default)
spring.datasource.password=YOUR_DATABASE_PASSWORD

# MySQL Driver
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# ============================================================================
# JPA/Hibernate Configuration
# ============================================================================
# DDL Auto: validate | update | create | create-drop
# - validate: Only validate existing schema (Production)
# - update: Update schema if needed (Development) 
# - create: Create new schema every time (Testing)
spring.jpa.hibernate.ddl-auto=update

# Show SQL queries in logs
spring.jpa.show-sql=true

# Hibernate Dialect for MySQL 8
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQL8Dialect

# ============================================================================
# Server Configuration
# ============================================================================
# Application Server Port
server.port=8080

# ============================================================================
# JWT Security Configuration
# ============================================================================
# JWT Secret Key - CHANGE THIS IN PRODUCTION!
# Use a strong random string at least 32 characters long
jwt.secret=tfms_super_secret_key_change_this_in_production

# JWT Token Expiration (in milliseconds)
# 86400000 = 24 hours
jwt.expiration=86400000

# ============================================================================
# Swagger/OpenAPI Configuration
# ============================================================================
# API Documentation path
springdoc.api-docs.path=/api-docs

# Swagger UI path
springdoc.swagger-ui.path=/swagger-ui.html

# ============================================================================
# Application Name (Optional)
# ============================================================================
spring.application.name=Traffic Fine Management System

# ============================================================================
# PRODUCTION NOTES
# ============================================================================
# Before deploying to production:
# 1. Change jwt.secret to a strong random value
# 2. Set hibernate.ddl-auto=validate (do NOT use update in production)
# 3. Use a strong database password
# 4. Use environment variables for all sensitive data
# 5. Enable HTTPS
# 6. Set proper CORS origins
